#!/bin/sh
### BEGIN INIT INFO
# Provides:          dropbear
# Required-Start:    $remote_fs $syslog $network
# Required-Stop:     $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Dropbear SSH server
# Description:       Lightweight SSH server for EtrayZ NAS
### END INIT INFO

NAME=dropbear
DAEMON=/usr/local/sbin/dropbear
PIDFILE=/var/run/dropbear.pid
DROPBEAR_PORT=22
DROPBEAR_EXTRA_ARGS=""
CONFDIR=/etc/dropbear

# Read config if exists
[ -r /etc/default/dropbear ] && . /etc/default/dropbear

# Exit if not installed
[ -x "$DAEMON" ] || exit 0

generate_keys() {
    mkdir -p "$CONFDIR"
    if [ ! -f "$CONFDIR/dropbear_rsa_host_key" ]; then
        echo "Generating RSA host key (first boot)..."
        /usr/local/bin/dropbearkey -t rsa -f "$CONFDIR/dropbear_rsa_host_key" -s 2048 > /dev/null 2>&1
    fi
    if [ ! -f "$CONFDIR/dropbear_ecdsa_host_key" ]; then
        echo "Generating ECDSA host key (first boot)..."
        /usr/local/bin/dropbearkey -t ecdsa -f "$CONFDIR/dropbear_ecdsa_host_key" > /dev/null 2>&1
    fi
}

case "$1" in
    start)
        generate_keys
        echo -n "Starting $NAME: "
        start-stop-daemon --start --quiet --pidfile "$PIDFILE" \
            --exec "$DAEMON" -- \
            -r "$CONFDIR/dropbear_rsa_host_key" \
            -r "$CONFDIR/dropbear_ecdsa_host_key" \
            -p "$DROPBEAR_PORT" \
            -P "$PIDFILE" \
            $DROPBEAR_EXTRA_ARGS
        echo "done."
        ;;
    stop)
        echo -n "Stopping $NAME: "
        start-stop-daemon --stop --quiet --pidfile "$PIDFILE" \
            --oknodo --exec "$DAEMON"
        rm -f "$PIDFILE"
        echo "done."
        ;;
    restart|force-reload)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "$NAME is running (PID $(cat "$PIDFILE"))"
        else
            echo "$NAME is not running"
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
exit 0
